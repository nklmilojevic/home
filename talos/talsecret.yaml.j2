# Talos secrets bundle, sourced entirely from 1Password via vals (ref+op://).
# Only consumed at bootstrap time to mint a client talosconfig
# (`talosctl gen config --with-secrets`). The machine PKI itself is injected
# into machineconfig.yaml.j2 directly. Never written to disk unencrypted.
cluster:
  id: ref+op://homecluster/talos/CLUSTER_ID
  secret: ref+op://homecluster/talos/CLUSTER_SECRET
secrets:
  bootstraptoken: ref+op://homecluster/talos/CLUSTER_TOKEN
  secretboxencryptionsecret: ref+op://homecluster/talos/CLUSTER_SECRETBOXENCRYPTIONSECRET
trustdinfo:
  token: ref+op://homecluster/talos/MACHINE_TOKEN
certs:
  etcd:
    crt: ref+op://homecluster/talos/CLUSTER_ETCD_CA_CRT
    key: ref+op://homecluster/talos/CLUSTER_ETCD_CA_KEY
  k8s:
    crt: ref+op://homecluster/talos/CLUSTER_CA_CRT
    key: ref+op://homecluster/talos/CLUSTER_CA_KEY
  k8saggregator:
    crt: ref+op://homecluster/talos/CLUSTER_AGGREGATORCA_CRT
    key: ref+op://homecluster/talos/CLUSTER_AGGREGATORCA_KEY
  k8sserviceaccount:
    key: ref+op://homecluster/talos/CLUSTER_SERVICEACCOUNT_KEY
  os:
    crt: ref+op://homecluster/talos/MACHINE_CA_CRT
    key: ref+op://homecluster/talos/MACHINE_CA_KEY
