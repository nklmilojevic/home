---
version: v1alpha1
persist: true
machine:
  ca:
    crt: ref+op://homecluster/talos/MACHINE_CA_CRT
    {% if ENV.CONTROLPLANE %}
    key: ref+op://homecluster/talos/MACHINE_CA_KEY
    {% endif %}
  certSANs:
    - 10.40.0.3
    - 127.0.0.1
  features:
    apidCheckExtKeyUsage: true
    diskQuotaSupport: true
    hostDNS:
      enabled: true
      forwardKubeDNSToHost: false # Cilium socketLB is disabled in this cluster
      resolveMemberNames: true
    kubePrism:
      enabled: true
      port: 7445
    {% if ENV.CONTROLPLANE %}
    kubernetesTalosAPIAccess:
      enabled: true
      allowedKubernetesNamespaces:
        - system-upgrade
      allowedRoles:
        - os:admin
    {% endif %}
    rbac: true
    stableHostname: true
  files:
    - op: create
      path: /etc/cri/conf.d/20-customization.part
      content: |-
        [plugins."io.containerd.cri.v1.images"]
          discard_unpacked_layers = false
    - op: overwrite
      path: /etc/nfsmount.conf
      permissions: 0o644
      content: |
        [ NFSMount_Global_Options ]
        nfsvers=3
        hard=True
        nolock=True
        async=True
        noatime=True
        nodiratime=True
        nconnect=16
        rsize=1048576
        wsize=1048576
  install:
    extraKernelArgs:
      - net.ifnames=1
    image: factory.talos.dev/installer/{{ ENV.SCHEMATIC }}:v1.13.4
    wipe: false
  kubelet:
    defaultRuntimeSeccompProfileEnabled: true
    disableManifestsDirectory: true
    extraConfig:
      allowedUnsafeSysctls:
        - net.ipv6.conf.*
      imageGCHighThresholdPercent: 70
      imageGCLowThresholdPercent: 55
    extraMounts:
      - destination: /var/openebs/local
        type: bind
        source: /var/openebs/local
        options:
          - bind
          - rshared
          - rw
    image: ghcr.io/siderolabs/kubelet:v1.36.2
    nodeIP:
      validSubnets:
        - 10.40.0.0/24
  network:
    disableSearchDomain: true
  nodeLabels:
    node.kubernetes.io/exclude-from-external-load-balancers: ""
  sysctls:
    fs.inotify.max_user_instances: "8192"
    fs.inotify.max_user_watches: "1048576"
    net.core.default_qdisc: fq
    net.core.netdev_max_backlog: "30000"
    net.core.rmem_max: "67108864"
    net.core.wmem_max: "67108864"
    net.ipv4.tcp_congestion_control: bbr
    net.ipv4.tcp_rmem: 4096 87380 33554432
    net.ipv4.tcp_tw_reuse: "1"
    net.ipv4.tcp_window_scaling: "1"
    net.ipv4.tcp_wmem: 4096 65536 33554432
    vm.nr_hugepages: "1024"
  time:
    disabled: false
    servers:
      - 162.159.200.1
      - 162.159.200.123
  token: ref+op://homecluster/talos/MACHINE_TOKEN
  udev:
    rules:
      - SUBSYSTEM=="drm", KERNEL=="renderD*", GROUP="44", MODE="0660"
      - SUBSYSTEMS=="usb", ATTRS{idVendor}=="1a6e", ATTRS{idProduct}=="089a", GROUP="20", MODE="0660"
      - SUBSYSTEMS=="usb", ATTRS{idVendor}=="18d1", ATTRS{idProduct}=="9302", GROUP="20", MODE="0660"
cluster:
  ca:
    crt: ref+op://homecluster/talos/CLUSTER_CA_CRT
    {% if ENV.CONTROLPLANE %}
    key: ref+op://homecluster/talos/CLUSTER_CA_KEY
    {% endif %}
  clusterName: home-kubernetes
  controlPlane:
    endpoint: https://10.40.0.3:6443
  discovery:
    enabled: true
    registries:
      kubernetes:
        disabled: true
      service:
        disabled: false
  id: ref+op://homecluster/talos/CLUSTER_ID
  network:
    cni:
      name: none
    dnsDomain: cluster.local
    podSubnets:
      - 10.69.0.0/16
    serviceSubnets:
      - 10.96.0.0/16
  secret: ref+op://homecluster/talos/CLUSTER_SECRET
  token: ref+op://homecluster/talos/CLUSTER_TOKEN
  {% if ENV.CONTROLPLANE %}
  aggregatorCA:
    crt: ref+op://homecluster/talos/CLUSTER_AGGREGATORCA_CRT
    key: ref+op://homecluster/talos/CLUSTER_AGGREGATORCA_KEY
  allowSchedulingOnControlPlanes: true
  apiServer:
    auditPolicy:
      apiVersion: audit.k8s.io/v1
      kind: Policy
      rules:
        - level: Metadata
    certSANs:
      - 10.40.0.3
      - 127.0.0.1
    disablePodSecurityPolicy: true
    extraArgs:
      enable-aggregator-routing: "true"
    image: registry.k8s.io/kube-apiserver:v1.36.2
  controllerManager:
    extraArgs:
      bind-address: 0.0.0.0
    image: registry.k8s.io/kube-controller-manager:v1.36.2
  coreDNS:
    disabled: true
  etcd:
    advertisedSubnets:
      - 10.40.0.0/24
    ca:
      crt: ref+op://homecluster/talos/CLUSTER_ETCD_CA_CRT
      key: ref+op://homecluster/talos/CLUSTER_ETCD_CA_KEY
    extraArgs:
      listen-metrics-urls: http://0.0.0.0:2381
  proxy:
    disabled: true
    image: registry.k8s.io/kube-proxy:v1.36.2
  scheduler:
    extraArgs:
      bind-address: 0.0.0.0
    image: registry.k8s.io/kube-scheduler:v1.36.2
  secretboxEncryptionSecret: ref+op://homecluster/talos/CLUSTER_SECRETBOXENCRYPTIONSECRET
  serviceAccount:
    key: ref+op://homecluster/talos/CLUSTER_SERVICEACCOUNT_KEY
  {% endif %}
